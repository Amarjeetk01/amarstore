{
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node"
      },
      {
        "src": "build/**",
        "use": "@vercel/static"
      }
    ],
    "routes": [
    
        {
          "src": "/products",
          "dest": "index.js"
        },
        {
          "src": "/products/(.*)",
          "dest": "index.js"
        },
        {
          "src": "/users",
          "dest": "index.js"
        },
        {
          "src": "/users/(.*)",
          "dest": "index.js"
        },
        {
          "src": "/brands",
          "dest": "index.js"
        },
        {
          "src": "/brands/(.*)",
          "dest": "index.js"
        },
        {
          "src": "/categories",
          "dest": "index.js"
        },
        {
          "src": "/categories/(.*)",
          "dest": "index.js"
        },
        {
          "src": "/carts",
          "dest": "index.js"
        },
        {
          "src": "/carts/(.*)",
          "dest": "index.js"
        },
        {
          "src": "/userinfoes",
          "dest": "index.js"
        },
        {
          "src": "/userinfoes/(.*)",
          "dest": "index.js"
        },
        {
          "src": "/create-payment-intent",
          "dest": "index.js"
        },
        {
          "src": "/create-payment-intent",
          "dest": "index.js"
        },
        {
            "src": "/(.*)",
            "dest": "/"
          }
      ]
    }